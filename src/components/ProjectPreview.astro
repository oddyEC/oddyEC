---
import type { CollectionEntry } from "astro:content";
import StatusBadge from "@components/StatusBadge.astro";
import TechTags from "@components/TechTags.astro";
import { withBase } from "@utils/paths";

interface Props {
  project: CollectionEntry<"projects">;
  slug: string;
}

const { project, slug } = Astro.props;
const caseStudyHref = withBase(`/projects/${slug}/`);
const repoUrl = project.data.repoUrl;
---

<article class="project-preview">
  <div class="project-preview-top">
    <StatusBadge status={project.data.status} />
    <h3>{project.data.title}</h3>
  </div>
  <div class="project-description">
    {project.data.description.slice(0, 2).map((paragraph) => <p>{paragraph}</p>)}
  </div>
  <TechTags tags={project.data.tags.slice(0, 4)} />
  <div class="project-actions">
    <a href={caseStudyHref}>Read case study</a>
    {repoUrl && <a href={repoUrl} target="_blank" rel="noreferrer">Repository</a>}
  </div>
</article>
